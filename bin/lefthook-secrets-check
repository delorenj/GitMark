#!/bin/bash
#
# Lefthook pre-commit script to detect potential secrets
# Checks staged files for common secret patterns and sensitive files
#

set -euo pipefail

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any secrets were found
FOUND_SECRETS=0

# List of sensitive file patterns to block
SENSITIVE_PATTERNS=(
    # Environment files
    "\.env$"
    "\.env\."
    "\.local$"
    
    # Credential files
    "credentials"
    "\.aws/credentials"
    "\.ssh/id_"
    "\.ssh/authorized_keys"
    "\.docker/config\.json"
    "\.netrc"
    "\.npmrc"
    "\.pypirc"
    "git-credentials"
    
    # Certificate and key files
    "\.pem$"
    "\.key$"
    "\.p12$"
    "\.pfx$"
    "\.crt$"
    "\.cer$"
    "\.der$"
    "id_rsa"
    "id_dsa"
    "id_ecdsa"
    "id_ed25519"
    
    # Database files
    "\.sqlite$"
    "\.sqlite3$"
    "\.db$"
    
    # Config files with secrets
    "config\.json$"
    "secrets\."
    "password"
    "passwd"
)

# Secret patterns to detect in file content
SECRET_PATTERNS=(
    # API Keys
    "api[_-]?key[[:space:]]*[=:][[:space:]]*[\"']?[a-zA-Z0-9_\-]{16,}[\"']?"
    "apikey[[:space:]]*[=:][[:space:]]*[\"']?[a-zA-Z0-9_\-]{16,}[\"']?"
    
    # AWS
    "AKIA[0-9A-Z]{16}"
    "aws[_-]?secret[_-]?access[_-]?key"
    "aws[_-]?access[_-]?key[_-]?id"
    
    # Generic secrets/tokens
    "secret[[:space:]]*[=:][[:space:]]*[\"']?[a-zA-Z0-9_\-]{8,}[\"']?"
    "password[[:space:]]*[=:][[:space:]]*[\"']?[^\"'\s]{4,}[\"']?"
    "passwd[[:space:]]*[=:][[:space:]]*[\"']?[^\"'\s]{4,}[\"']?"
    "token[[:space:]]*[=:][[:space:]]*[\"']?[a-zA-Z0-9_\-]{16,}[\"']?"
    
    # Private keys
    "BEGIN[[:space:]]+(RSA|DSA|EC|OPENSSH|PGP)[[:space:]]+PRIVATE[[:space:]]+KEY"
    
    # GitHub tokens
    "gh[pousr]_[A-Za-z0-9_]{36,}"
    "github[_-]?token"
    
    # Slack tokens
    "xox[baprs]-[0-9]{10,13}-[0-9]{10,13}(-[a-zA-Z0-9]{24})?"
    
    # Generic high-entropy strings that look like secrets
    "[\"']?sk-[a-zA-Z0-9]{20,}[\"']?"
    "[\"']?sk_live_[a-zA-Z0-9]{20,}[\"']?"
    "[\"']?sk_test_[a-zA-Z0-9]{20,}[\"']?"
)

# Files to skip (test fixtures, examples, etc)
SKIP_PATTERNS=(
    "\.md$"
    "test/fixtures"
    "__tests__"
    "\.test\."
    "\.spec\."
    "example"
    "sample"
    "\.example$"
    "\.template$"
    "lefthook-secrets-check$"  # Skip this script itself
)

# Function to check if a file should be skipped
should_skip_file() {
    local file="$1"
    for pattern in "${SKIP_PATTERNS[@]}"; do
        if echo "$file" | grep -qiE "$pattern"; then
            return 0
        fi
    done
    return 1
}

# Function to check filename against sensitive patterns
check_filename() {
    local file="$1"
    
    for pattern in "${SENSITIVE_PATTERNS[@]}"; do
        if echo "$file" | grep -qiE "$pattern"; then
            echo -e "${RED}ERROR: Sensitive file detected: $file${NC}"
            echo "       Pattern matched: $pattern"
            return 1
        fi
    done
    return 0
}

# Function to check file content for secret patterns
check_content() {
    local file="$1"
    
    # Skip binary files and very large files
    if file "$file" | grep -qE "(binary|executable|archive|image)"; then
        return 0
    fi
    
    # Skip files larger than 500KB
    local size
    size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
    if [[ "$size" -gt 512000 ]]; then
        return 0
    fi
    
    for pattern in "${SECRET_PATTERNS[@]}"; do
        if grep -inE "$pattern" "$file" 2>/dev/null; then
            echo -e "${RED}ERROR: Potential secret found in: $file${NC}"
            echo "       Pattern: $pattern"
            echo "       Match: $(grep -inE "$pattern" "$file" 2>/dev/null | head -1)"
            return 1
        fi
    done
    return 0
}

# Main execution
echo "🔍 Checking for secrets in staged files..."

# Get list of staged files from arguments or git
if [[ $# -eq 0 ]]; then
    # No arguments, get staged files from git
    mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
else
    STAGED_FILES=("$@")
fi

# Exit early if no staged files
if [[ ${#STAGED_FILES[@]} -eq 0 ]] || [[ -z "${STAGED_FILES[0]}" ]]; then
    echo "✅ No staged files to check"
    exit 0
fi

# Check each staged file
for file in "${STAGED_FILES[@]}"; do
    # Skip deleted files
    [[ -f "$file" ]] || continue
    
    # Skip files that match ignore patterns
    if should_skip_file "$file"; then
        continue
    fi
    
    # Check filename
    if ! check_filename "$file"; then
        FOUND_SECRETS=1
        continue
    fi
    
    # Check file content
    if ! check_content "$file"; then
        FOUND_SECRETS=1
    fi
done

# Exit with appropriate code
if [[ $FOUND_SECRETS -eq 1 ]]; then
    echo ""
    echo -e "${YELLOW}To bypass this check (NOT RECOMMENDED):${NC} git commit --no-verify"
    echo -e "${YELLOW}To add an exception:${NC} Edit .lefthook-ignore or lefthook.yml"
    exit 1
else
    echo "✅ No secrets detected"
    exit 0
fi
